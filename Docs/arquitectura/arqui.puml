@startuml Arquitectura OSDS: Centro de Salud Digital
title Arquitectura General del Sistema Distribuido (3 VMs en GCP)

skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

' Colores
skinparam node {
    BorderColor #1E3A8A
    BackgroundColor #EFF6FF
}
skinparam database {
    BorderColor #0D9488
    BackgroundColor #F0FDFA
}
skinparam cloud {
    BorderColor #0284C7
    BackgroundColor #F0F9FF
}

cloud "Internet (Acceso Seguro TLS)" as INTERNET {
    actor "Usuario / Personal Clinico" as CLIENT
    note bottom of CLIENT
        Acceso mediante navegador
        https://osdsp3.epistia.cl
    end note
}

node "VM 3: Gateway (vm-gateway)\nIP Publica: 104.154.143.133\nIP Privada: 10.128.0.30" as VMGATEWAY {
    component "cloudflare-tunnel\n(Cliente Cloudflared)" as TUNNEL
    component "nginx-proxy\n(Proxy Inverso / Ports: 80/443)" as NGINX
    
    TUNNEL -[#blue]-> NGINX : Enruta trafico interno\n(nginx-proxy:80)
}

CLIENT -[#red,bold]-> TUNNEL : Conexion HTTPS/WSS\n(gRPC tunel inverso)

node "VM 1: Hospital Local (vm-hospital-local)\nIP Privada: 10.128.0.10" as VMHOSPITAL {
    component "app-estaciones\n(WebSocket Server - Port 8001)" as ESTACIONES
    database "db-local (PostgreSQL 16)\n(Cache Clinica Local - Port 5432)" as DBLOCAL
    
    ESTACIONES -[#green]-> DBLOCAL : Consultas SQL locales\n(Baja latencia)
}

node "VM 2: Nube Central (vm-nube-central)\nIP Privada: 10.128.0.20" as VMNUBE {
    component "app-terminales\n(WebSocket Server - Port 8002)" as TERMINALES
    database "db-nube (PostgreSQL 16)\n(BD Core Central - Port 5432)" as DBNUBE
    
    TERMINALES -[#green]-> DBNUBE : Persistencia core\nde admisiones
}

' Flujos de Nginx
NGINX -[#orange,dashed]-> ESTACIONES : Proxy /ws-medicas\n(Port 8001)
NGINX -[#orange,dashed]-> TERMINALES : Proxy /ws-administrativas\n(Port 8002)

' Canal de Replicacion Logica
DBLOCAL <.[#purple,bold].> DBNUBE : Replicacion Logica Bidireccional\n(Port 5432 / VPC Interna GCP)\norigin = none / WHERE origen_registro
note top of DBLOCAL
  Suscripcion: sub_desde_nube
  Publicacion: pub_local_a_nube
end note
note top of DBNUBE
  Suscripcion: sub_desde_local
  Publicacion: pub_nube_a_local
end note

@enduml